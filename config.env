# TideWatch Configuration
# ========================

# 日志级别: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# CopilotX LLM 配置 (用于叙事润色)
COPILOTX_API_BASE=https://api.polly.wang/v1
# COPILOTX_API_KEY 在 .env 中配置（不提交到 git）
COPILOTX_MODEL=claude-sonnet-4

# 数据源配置
# 默认使用 AKShare (免费，无需配置)
# 后续可添加雪球等数据源
# XUEQIU_COOKIE=your-xueqiu-cookie
